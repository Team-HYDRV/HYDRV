<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.HYDRV" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/settings_section_icon_bg_selected</item>
        <item name="colorOnPrimaryContainer">@color/text</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/settings_section_icon_bg_selected</item>
        <item name="colorOnSecondaryContainer">@color/text</item>
        <item name="colorOnBackground">@color/text</item>
        <item name="colorSurface">@color/card</item>
        <item name="colorOnSurface">@color/text</item>
        <item name="colorSurfaceVariant">@color/nav_surface</item>
        <item name="colorOnSurfaceVariant">@color/subtext</item>
        <item name="colorOutline">@color/card_stroke</item>
        <item name="colorError">@color/red</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:colorControlHighlight">#00000000</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.HYDRV.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.HYDRV.MaterialAlertDialog</item>
    </style>

    <style name="Theme.HYDRV.Material" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:colorBackground">@color/dynamic_bg</item>
        <item name="colorSurface">@color/dynamic_card</item>
        <item name="colorSurfaceVariant">@color/dynamic_nav_surface</item>
        <item name="colorSurfaceContainerLow">@color/dynamic_card</item>
        <item name="colorSurfaceContainerHigh">@color/dynamic_elevated</item>
        <item name="colorOutline">@color/dynamic_stroke</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:colorControlHighlight">#00000000</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.HYDRV.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.HYDRV.MaterialAlertDialog</item>
    </style>

    <style
        name="ThemeOverlay.HYDRV.MaterialAlertDialog"
        parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="alertDialogStyle">@style/Widget.HYDRV.MaterialAlertDialog</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.HYDRV.Dialog</item>
    </style>

    <style
        name="Widget.HYDRV.MaterialAlertDialog"
        parent="MaterialAlertDialog.MaterialComponents">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.HYDRV.Dialog</item>
        <item name="backgroundTint">@color/card</item>
    </style>

    <style name="ShapeAppearanceOverlay.HYDRV.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">24dp</item>
        <item name="cornerSizeBottomRight">24dp</item>
    </style>
</resources>
