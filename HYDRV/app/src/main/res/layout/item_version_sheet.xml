<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/versionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnBackground"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/versionBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/version_badge_latest"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/latest"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/versionChangelog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/versionMetaRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/versionSourceBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/version_badge_latest"
            android:paddingHorizontal="9dp"
            android:paddingVertical="4dp"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/versionSourceHost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/versionInstalledHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="?attr/colorPrimary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/versionDownloadedHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/version_hint_downloaded"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:textColor="@color/text_on_dark_chip"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/versionActionRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/versionDownloadButton"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@android:color/transparent">

            <FrameLayout
                android:id="@+id/versionDownloadTrack"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/version_download_button_bg"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/versionDownloadFill"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToOutline="true"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/version_download_fill_clip" />

                <LinearLayout
                    android:id="@+id/versionDownloadContent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/versionDownloadIcon"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_check_small"
                        app:tint="?attr/colorOnPrimaryContainer"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/versionDownloadLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/download_label"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <app.hydra.manager.WiggleCircularProgressIndicator
                    android:id="@+id/versionInstallProgress"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    />
            </FrameLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/versionUninstallButton"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@drawable/button_delete_version_sheet"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/versionUninstallLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:includeFontPadding="false"
                android:text="@string/downloads_uninstall"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <app.hydra.manager.WiggleCircularProgressIndicator
                android:id="@+id/versionUninstallProgress"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:visibility="gone"
                />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
