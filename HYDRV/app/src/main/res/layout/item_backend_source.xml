<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/card"
    android:orientation="vertical"
    android:paddingLeft="14dp"
    android:paddingTop="12dp"
    android:paddingRight="14dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:id="@+id/backendSourceTopRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/backendSourceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/colorOnBackground"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/backendSourceActiveButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/backend_chip_primary"
            android:backgroundTint="@null"
            android:textAllCaps="false"
            android:textColor="?attr/colorOnPrimary"
            android:minWidth="0dp"
            android:minEms="0"
            android:stateListAnimator="@null"
            android:paddingLeft="12dp"
            android:paddingTop="5dp"
            android:paddingRight="12dp"
            android:paddingBottom="5dp"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/backendSourceActionRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="start"
        android:orientation="horizontal">

        <Button
            android:id="@+id/backendSourceEditButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/backend_chip_secondary"
            android:backgroundTint="@null"
            android:textAllCaps="false"
            android:textColor="?attr/colorOnSurface"
            android:minWidth="0dp"
            android:minEms="0"
            android:stateListAnimator="@null"
            android:paddingLeft="12dp"
            android:paddingTop="5dp"
            android:paddingRight="12dp"
            android:paddingBottom="5dp"
            android:text="@string/backend_edit_source"
            android:textSize="11sp" />

        <Button
            android:id="@+id/backendSourceRemoveButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/backend_chip_secondary"
            android:backgroundTint="@null"
            android:textAllCaps="false"
            android:textColor="?attr/colorOnSurface"
            android:minWidth="0dp"
            android:minEms="0"
            android:stateListAnimator="@null"
            android:paddingLeft="12dp"
            android:paddingTop="5dp"
            android:paddingRight="12dp"
            android:paddingBottom="5dp"
            android:text="@string/backend_remove_source"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
