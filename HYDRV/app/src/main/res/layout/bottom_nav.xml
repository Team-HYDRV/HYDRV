<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:gravity="center"
    android:paddingHorizontal="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="28dp"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/navContainer"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/nav_bg"
        android:elevation="10dp"
        android:paddingHorizontal="28dp">

        
        <FrameLayout
            android:id="@+id/nav_home_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/nav_home"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_home"
                android:scaleType="centerInside" />
        </FrameLayout>

        
        <FrameLayout
    android:id="@+id/nav_download_tab"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/nav_download"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:contentDescription="@string/downloads_title"
        android:src="@drawable/ic_download"
        android:scaleType="centerInside"/>

    
    <View
        android:id="@+id/nav_badge_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_gravity="center"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/badge_red"
        android:elevation="4dp"
        android:visibility="gone"/>

</FrameLayout>

        
        <FrameLayout
            android:id="@+id/nav_settings_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/nav_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/settings_title"
                android:src="@drawable/ic_settings"
                android:scaleType="centerInside" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
