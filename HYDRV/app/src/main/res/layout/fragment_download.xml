<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/headerContainer"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/titleDownloads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/downloads_title"
            android:textColor="?attr/colorOnBackground"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/defaultHeaderRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/downloadCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/downloads_no_items_count"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp" />

        <TextView
            android:id="@+id/buttonSelectMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
            android:background="@drawable/download_select_button"
            android:gravity="center"
            android:minWidth="72dp"
            android:text="@string/downloads_select_mode"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/selectionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/selectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/downloads_no_selected"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buttonSelectAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/download_selection_button_green"
            android:gravity="center"
            android:text="@string/downloads_select_all"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp" />

        <TextView
            android:id="@+id/buttonDeleteSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/download_selection_button_red"
            android:gravity="center"
            android:text="@string/downloads_delete"
            android:textColor="?attr/colorOnError"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp" />

        <TextView
            android:id="@+id/buttonCancelSelection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/download_selection_button_neutral"
            android:gravity="center"
            android:text="@string/downloads_cancel"
            android:textColor="?attr/colorOnSurface"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp" />
    </LinearLayout>

    
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerDownloads"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="196dp"/>

        
        <TextView
            android:id="@+id/emptyText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/downloads_empty"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone"/>

    </FrameLayout>

</LinearLayout>




