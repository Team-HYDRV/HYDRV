<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <alpha
        android:duration="160"
        android:fromAlpha="1"
        android:interpolator="@android:interpolator/fast_out_linear_in"
        android:toAlpha="0" />
    <translate
        android:duration="160"
        android:fromYDelta="0%"
        android:interpolator="@android:interpolator/fast_out_linear_in"
        android:toYDelta="-4%" />
</set>
